# Copy this file to .env and fill in the values before running docker compose up
DJANGO_SECRET_KEY=REPLACE_ME_WITH_A_LONG_RANDOM_SECRET_KEY
DEBUG=False
# Use * to allow all hostnames (suitable for self-hosted VPS deployments).
# To restrict access, replace * with a comma-separated list of allowed
# hostnames or IP addresses, e.g.: ALLOWED_HOSTS=example.com,192.168.1.100
ALLOWED_HOSTS=*
